# =============================================================================
# Komodo Stack Environment Variables
# Copy this as reference when configuring Stack Environments in Komodo UI.
# Use Komodo Secrets for sensitive values (POSTGRES_PASSWORD, SERVICE_PWD_KEY, etc).
# =============================================================================

# -----------------------------------------------------------------------------
# Stack: infra (docker-compose.infra.yml)
# -----------------------------------------------------------------------------
POSTGRES_USER=app_user
POSTGRES_PASSWORD=dev_only_pwd
POSTGRES_DB=app_db

# -----------------------------------------------------------------------------
# Stack: app (docker-compose.app.yml)
# -----------------------------------------------------------------------------
# Must match infra stack
POSTGRES_USER=app_user
POSTGRES_PASSWORD=dev_only_pwd
POSTGRES_DB=app_db
REGISTRY_HOST=127.0.0.1

# App image tag (default: latest)
APP_VERSION=latest

# Web server env (use Secrets for keys)
SERVICE_PWD_KEY=SWFtQVZlcnlTZWNyZXRQd2RLZXlGb3JEZXY
SERVICE_TOKEN_KEY=SWFtQVZlcnlTZWNyZXRUb2tlbktleUZvckRldg
SERVICE_TOKEN_DURATION_SEC=86400
INIT_ADMIN_USERNAME=demo1
INIT_ADMIN_PASSWORD=demo1

# Optional overrides
RUST_LOG=web_server=info,lib_core=info,lib_web=info,lib_auth=info
SERVICE_VALKEY_URL=redis://valkey:6379
SERVICE_VALKEY_POOL_MAX_SIZE=10
SERVICE_VALKEY_POOL_MIN_IDLE=2
SERVICE_PERMISSION_CACHE_ENABLED=true

# Gateway
GATEWAY_LOG_LEVEL=info
